# =============================================================================
# Reyla Logistics — WatchTower Observability Stack
# Copy this file to .env and fill in real values before running.
#   cp .env.example .env
# NEVER commit the real .env file — it is listed in .gitignore.
# =============================================================================

# ---------------------------------------------------------------------------
# App service ports (host-side port binding)
# ---------------------------------------------------------------------------
ORDER_SERVICE_PORT=3001       # Port exposed to the host for order-service
TRACKING_SERVICE_PORT=3002    # Port exposed to the host for tracking-service
NOTIFICATION_SERVICE_PORT=3003 # Port exposed to the host for notification-service

# ---------------------------------------------------------------------------
# Prometheus
# ---------------------------------------------------------------------------
PROMETHEUS_PORT=9090           # Host port for the Prometheus UI / API

# ---------------------------------------------------------------------------
# Grafana
# ---------------------------------------------------------------------------
GRAFANA_PORT=3000                      # Host port for the Grafana UI
GF_SECURITY_ADMIN_USER=admin           # Grafana admin username
GF_SECURITY_ADMIN_PASSWORD=change me    # Grafana admin password — change this!

# ---------------------------------------------------------------------------
# Alertmanager
# ---------------------------------------------------------------------------
ALERTMANAGER_PORT=9093         # Host port for the Alertmanager UI
