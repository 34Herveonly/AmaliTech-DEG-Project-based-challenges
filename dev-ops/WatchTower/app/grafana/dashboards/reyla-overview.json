      "title": "P95 Response Latency (per service)",
      "description": "95th percentile response time per service derived from http_request_duration_seconds_bucket histogram. If the panel shows No Data the services need histogram instrumentation added (the current services use only a Counter).",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le, job))",
          "legendFormat": "p95 - {{job}}",
          "refId": "A"
        }
      ]
